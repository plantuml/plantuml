---
output: svg
---
@startuml
<style>
file {
  BackGroundColor #b
  LineThickness 1
  LineColor black
}
folder {
  BackGroundColor #pink
  LineThickness 1
  LineColor black
}
frame {
  BackGroundColor #palegreen
  LineThickness 1
  LineColor black
}
package {
  BackGroundColor #LightSkyBlue
  LineThickness 1
  LineColor black
}
</style>
rectangle OK {
folder folder
frame frame
package package
}
rectangle package_KO {
folder e7 as "folder" {
file f7
}
frame e8 as "frame" {
file f8
}
package e11 as "package" {
file f11
}
}
@enduml
