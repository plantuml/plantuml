@startuml

left to right direction
state Somp {
  state entry1 <<expansionInput>>
  state entry2 <<expansionInput>>
  state sin
  entry1 --> sin
  entry2 -> sin
  sin -> sin2
  state exitA <<expansionOutput>>
  sin2 --> exitA
}

[*] --> Somp.entry1
Somp.exitA --> Foo
Foo1 -> Somp.entry2

@enduml
