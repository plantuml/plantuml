---
output: svg
---
@startyaml
<style>
yamlDiagram {
  node {
    BackGroundColor black
    LineColor lightblue
    FontName Helvetica
    FontColor #CCFF02
    FontSize 18
    FontStyle bold
    RoundCorner 0
    LineThickness 2
    LineStyle 10-5
    separator {
      LineThickness 0.5
      LineColor black
      LineStyle 1-5
    }
    highlight {
	  BackGroundColor red
	  FontColor white
      FontStyle italic
    }
  }
  arrow {
    BackGroundColor lightblue
    LineColor green
    LineThickness 2
    LineStyle 2-5
  }
}
</style>
#highlight "fruit"
fruit: Apple
size: Large
color: Red
@endyaml
