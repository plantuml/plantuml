---
output: svg
---
@startuml
<style>
arrow {
	.dotted, .dashed {
	  LineColor orange
	  FontColor orange
	}
	.dotted {
	  LineStyle 1-3
	}
	.dashed {
	  LineStyle 7-7
	}
}
</style>


rectangle "<$person>\n==A" <<person>> as a
rectangle "==S" <<system>> as s
rectangle "==E" <<external_system>> as e

a -->> s <<dotted>> : **calls via UI**
s -->> e <<dashed>> : **calls external**
@enduml
